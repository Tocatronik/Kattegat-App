# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# Vercel-only (server-side, not needed for dev unless testing API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=...
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...
ANTHROPIC_API_KEY=...

# API protection — generate a random token (e.g., openssl rand -hex 32)
# Same value in:
#   - Vercel server-side env: APP_API_TOKEN
#   - Vercel client-side env: VITE_APP_API_TOKEN
APP_API_TOKEN=
VITE_APP_API_TOKEN=
